############################################################
## FIMS SAM-style build system (Option A - conservative)
############################################################

## ---------------------------------------------------------
## Compiler flags
## ---------------------------------------------------------

PKG_CPPFLAGS = -I../inst/include \
               -I../inst/include/FIMS \
               -I../inst/include/common \
			   -I../inst/include/population_dynamics/selectivity \
			   -I../inst/include/population_dynamics/selectivity/functors \
               -DTMB_SAFEBOUNDS \
               -DTMB_MODEL \
			   -DTMBAD_FRAMEWORK  \
               -DFIMS_DEPENDS\(x\)=\#include\ \"x\"

PKG_CXXFLAGS = -g -O0

## ---------------------------------------------------------
## Discover FIMS header modules
## ---------------------------------------------------------

FIMS_DIR = ../inst/include/FIMS

FIMS_FILES_IN = $(wildcard $(FIMS_DIR)/*.hpp)

## Generated files
FIMS_SRC    = $(patsubst $(FIMS_DIR)/%, F_%, $(FIMS_FILES_IN:.hpp=.cpp))
FIMS_HEADER = $(patsubst $(FIMS_DIR)/%, F_%, $(FIMS_FILES_IN:.hpp=.h))

## User source files (exclude generated ones)
SRC_FILES = $(filter-out $(wildcard F_*.cpp),$(wildcard *.cpp))

## ---------------------------------------------------------
## Objects and dependencies
## ---------------------------------------------------------

DEPENDS = $(FIMS_SRC:.cpp=.d)
OBJECTS = $(FIMS_SRC:.cpp=.o) $(SRC_FILES:.cpp=.o)

## ---------------------------------------------------------
## Helper macros
## ---------------------------------------------------------

writeToFile = echo $(2) $(1)
fileToFile  = cat $(2) $(1)

## Extract FIMS dependencies from header
dependencies = sed -n -E 's/FIMS_DEPENDS\((.+)\)/F_\1.h/p' $(1)

## ---------------------------------------------------------
## Prevent deletion of generated files
## ---------------------------------------------------------

.PRECIOUS: $(FIMS_SRC) $(FIMS_HEADER) FIMS.h

## ---------------------------------------------------------
## Main target
## ---------------------------------------------------------

all: $(SHLIB)

## ---------------------------------------------------------
## Force rebuilds when umbrella header changes
## ---------------------------------------------------------

%.o: FIMS.h

## ---------------------------------------------------------
## Generate dependency files (.d)
## ---------------------------------------------------------

F_%.d: $(FIMS_DIR)/%.hpp
	@echo Generating $@
	@echo "F_$*.o F_$*.d: F_$*.cpp F_$*.h $(shell $(call dependencies, $^))" > $@

## ---------------------------------------------------------
## Generate headers (F_*.h)
## ---------------------------------------------------------

F_%.h: $(FIMS_DIR)/%.hpp
	@echo Generating $@

	@echo "// Autogenerated file" > $@
	@echo "#ifndef FIMS_AUTO_$*_H_" >> $@
	@echo "#define FIMS_AUTO_$*_H_" >> $@

	@echo "#define WITH_LIBTMB" >> $@
	@echo "#include \"TMB.h\"" >> $@

	## Copy original header
	@cat $^ >> $@

	@echo "#endif" >> $@

	## Convert FIMS_DEPENDS(...) → includes
	@sed -i'.bak' -E 's/FIMS_DEPENDS\((.+)\)/#include "F_\1.h"/g' $@

	## OPTIONAL: fix deep relative includes (safe normalization)
	## This removes "../../../" patterns so includes work with -I paths
	@sed -i'.bak2' -E 's#\.\./\.\./\.\./##g' $@

## ---------------------------------------------------------
## Generate source files (F_*.cpp)
## ---------------------------------------------------------

F_%.cpp: $(FIMS_DIR)/%.hpp
	@echo Generating $@

	@echo "// Autogenerated file" > $@
	@echo "#define WITH_LIBTMB" >> $@
	@echo "#include \"F_$*.h\"" >> $@

	## Include preprocessor if needed (optional)
	@echo "#include \"../inst/include/SAM_preprocessor.h\"" >> $@

	## Copy original header contents
	@cat $^ >> $@

## ---------------------------------------------------------
## Umbrella header (FIMS.h)
## ---------------------------------------------------------

FIMS.h: $(FIMS_HEADER)
	@echo Generating $@
	@echo "// Autogenerated file" > $@
	@for O in $(^); do echo "#include \"$$O\"" >> $@; done

## ---------------------------------------------------------
## Clean
## ---------------------------------------------------------

clean:
	rm -f $(FIMS_SRC) $(FIMS_HEADER) FIMS.h $(DEPENDS) *.o *.so *.bak *.bak2

## ---------------------------------------------------------
## Include dependency files
## ---------------------------------------------------------

-include $(DEPENDS)
