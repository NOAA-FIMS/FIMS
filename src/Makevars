############################################################
## FIMS SAM-style build system (FLATTENED + FIXED)
############################################################

## ---------------------------------------------------------
## Compiler flags
## ---------------------------------------------------------

PKG_CPPFLAGS = -I../inst/include \
               -I../inst/include/FIMS \
               -I../inst/include/common \
			   -I../inst/include/population_dynamics \
			   -I../inst/include/population_dynamics/selectivity \
               -DTMB_SAFEBOUNDS \
               -DTMB_MODEL \
               -DTMBAD_FRAMEWORK  

PKG_CXXFLAGS = -g -O0

## ---------------------------------------------------------
## FIMS header location
## ---------------------------------------------------------

FIMS_DIR = ../inst/include/FIMS

## Recursively find ALL headers
FIMS_FILES_IN = $(shell find $(FIMS_DIR) -name "*.hpp")

## Strip directory → just basename
FIMS_BASENAME = $(notdir $(FIMS_FILES_IN:.hpp=))

## Generated files (flattened)
FIMS_SRC    = $(addprefix F_, $(addsuffix .cpp,$(FIMS_BASENAME)))
FIMS_HEADER = $(addprefix F_, $(addsuffix .h,$(FIMS_BASENAME)))

## User source files
SRC_FILES = $(filter-out $(wildcard F_*.cpp),$(wildcard *.cpp))

## Objects
OBJECTS = $(FIMS_SRC:.cpp=.o) $(SRC_FILES:.cpp=.o)

## Dependency files
DEPENDS = $(FIMS_SRC:.cpp=.d)

## ---------------------------------------------------------
## Helper: find original header by basename
## ---------------------------------------------------------

find_header = $(shell find $(FIMS_DIR) -name $(1).hpp | head -n 1)

## ---------------------------------------------------------
## Extract dependencies (strip paths!)
## ---------------------------------------------------------

dependencies = sed -n -E 's|FIMS_DEPENDS\(.*/([^/]+)\.hpp\)|F_\1.h|p; s|FIMS_DEPENDS\(([^/]+)\.hpp\)|F_\1.h|p' $(1)

## ---------------------------------------------------------
## Prevent deletion
## ---------------------------------------------------------

.PRECIOUS: $(FIMS_SRC) $(FIMS_HEADER) FIMS.h

## ---------------------------------------------------------
## Main target
## ---------------------------------------------------------

all: $(SHLIB)

## ---------------------------------------------------------
## Force rebuild if umbrella changes
## ---------------------------------------------------------

%.o: FIMS.h

## ---------------------------------------------------------
## Generate dependency files
## ---------------------------------------------------------

F_%.d:
	@echo Generating $@
	@HDR=$(call find_header,$*); \
	echo "F_$*.o F_$*.d: F_$*.cpp F_$*.h $$( $(call dependencies,$$HDR) )" > $@

## ---------------------------------------------------------
## Generate headers (FLATTENED)
## ---------------------------------------------------------

F_%.h:
	@echo Generating $@
	@HDR=$(call find_header,$*); \
	echo "// Autogenerated file" > $@; \
	echo "#ifndef FIMS_AUTO_$*_H_" >> $@; \
	echo "#define FIMS_AUTO_$*_H_" >> $@; \
	echo "#define WITH_LIBTMB" >> $@; \
	echo "#include \"TMB.h\"" >> $@; \
	cat $$HDR >> $@; \
	echo "#endif" >> $@; \
	sed -i'.bak' -E 's|FIMS_DEPENDS\(.*/([^/]+)\.hpp\)|#include "F_\1.h"|g' $@; \
	sed -i'.bak2' -E 's|FIMS_DEPENDS\(([^/]+)\.hpp\)|#include "F_\1.h"|g' $@; \
	sed -i'.bak3' -E 's#\.\./\.\./\.\./##g' $@

## ---------------------------------------------------------
## Generate source files
## ---------------------------------------------------------

F_%.cpp:
	@echo Generating $@
	@HDR=$(call find_header,$*); \
	echo "// Autogenerated file" > $@; \
	echo "#define WITH_LIBTMB" >> $@; \
	echo "#include \"F_$*.h\"" >> $@; \
	echo "#include \"../inst/include/SAM_preprocessor.h\"" >> $@; \
	cat $$HDR >> $@

## ---------------------------------------------------------
## Umbrella header
## ---------------------------------------------------------

FIMS.h: $(FIMS_HEADER)
	@echo Generating $@
	@echo "// Autogenerated file" > $@
	@for O in $(^); do echo "#include \"$$O\"" >> $@; done

## ---------------------------------------------------------
## Clean
## ---------------------------------------------------------

clean:
	rm -f F_*.cpp F_*.h FIMS.h *.o *.so *.d *.bak *.bak2 *.bak3

## ---------------------------------------------------------
## Include dependencies
## ---------------------------------------------------------

-include $(DEPENDS)