CXX_STD = CXX17
# The -fno-gnu-unique flag disables GNU unique symbol handling (needed for some Linux builds)
ifeq ($(shell uname), Linux)
PKG_CXXFLAGS = -DTMB_MODEL -DTMB_EIGEN_DISABLE_WARNINGS -DTMBAD_FRAMEWORK -fno-gnu-unique
else
PKG_CXXFLAGS = -DTMB_MODEL -DTMB_EIGEN_DISABLE_WARNINGS -DTMBAD_FRAMEWORK
endif
CXX17STD = -std=c++17 -w
USE_CXX17 = "yes"
