{
  "version": "0.2",
  "language": "en",
  "dictionaryDefinitions": [
    {
      "name": "fims-dict",
      "path": "./fims-dict.txt",
      "addWords": true
    }
  ],
  "dictionaries": [
    "fims-dict",
    "cpp",
    "r",
    "softwareTerms"
  ],
  "ignorePaths": [
    "inst/WORDLIST",
